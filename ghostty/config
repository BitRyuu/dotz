font-family = JetBrains Mono Regular
font-size = 17
window-title-font-family = JetBrains Mono Regular 

theme = "Catppuccin Mocha"

#custom-shader = shaders/inside-the-matrix.glsl
#custom-shader = shaders/bettercrt.glsl
custom-shader = shaders/cursor_blaze.glsl
custom-shader = shaders/cursur_smear.glsl

shell-integration-features = no-cursor
cursor-style = block
cursor-color = f5c7fc

background-opacity = 0.85
background-blur = 20
#background-blur-radius = 1

window-padding-x = 20
window-padding-y = 5
window-height = 22
window-width = 60
window-position-x = 370
window-position-y = 130

window-decoration = auto
macos-titlebar-proxy-icon = hidden
macos-window-buttons = hidden

macos-icon = blueprint

keybind = global:ctrl+grave_accent=toggle_quick_terminal
